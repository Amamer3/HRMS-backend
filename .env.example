# Database (local dev)
DATABASE_URL=postgresql://echt:passecht026@localhost:5432/echt_hr?schema=public

# Docker Compose PostgreSQL (used when overriding in compose)
POSTGRES_USER=echt
POSTGRES_PASSWORD=passecht026
POSTGRES_DB=echt_hr

# API
NODE_ENV=development
PORT=4000
PUBLIC_API_URL=https://api.echt.example.com

# Microsoft Entra ID (OIDC / JWT validation)
# Replace placeholders with your tenant/app registration values before validating real tokens.
AZURE_AD_TENANT_ID=00000000-0000-0000-0000-000000000001
AZURE_AD_CLIENT_ID=00000000-0000-0000-0000-000000000002
AZURE_AD_CLIENT_SECRET=
AZURE_AD_ISSUER=https://login.microsoftonline.com/00000000-0000-0000-0000-000000000001/v2.0
AZURE_AD_AUDIENCE=api://00000000-0000-0000-0000-000000000002
AZURE_AD_AUTH_SCOPE=openid profile email offline_access user.read

# Optional: MS Graph (application permissions) for email notifications
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=

# Traefik / compose (production)
ACME_EMAIL=ops@echtenvironmental.com
API_HOST=api.echt.example.com
